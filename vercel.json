{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm build:tokens && pnpm --filter @origon/docs build",
  "installCommand": "pnpm install --frozen-lockfile",
  "outputDirectory": "apps/docs/.next",
  "framework": "nextjs",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- apps/docs packages/react packages/tokens-react tokens/"
}
